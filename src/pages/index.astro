---
import { Globe, Linkedin, LinkedinIcon } from 'lucide-react';
import MainLayout from '../layouts/MainLayout.astro';
const withBase = (path = '') => {
  const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
  return `${base}${path}`;
};
const profileImage = withBase('images/about.png');

const cards = [
  {
    title: '¿Quién soy?',
    text: 'Soy una persona apasionada por el aprendizaje y la búsqueda de nuevo conocimiento. Creo firmemente que aprender es uno de los mayores placeres de la vida. Quiero compartir la búsqueda de mi lugar en el mundo.',
    href: withBase('about/'),
    cta: 'Más sobre quién soy'
  },
  {
    title: 'Escribo mis ideas',
    text: 'Mi versión del mundo. Aquí comparto mis ideas, mis sueños, mis frustraciones y más. Puedes conocerme con leer un poco.',
    href: withBase('blog/'),
    cta: 'Ver mi blog'
  },
  {
    title: 'Notas',
    text: 'Notas personales sobre mis intereses y estudios. Está un poco desorganizado, pero con suerte se encuentra algo divertido.',
    href: withBase('notas/'),
    cta: 'Explorar notas'
  },
  {
    title: 'Proyectos personales',
    text: 'Experimentos y proyectos en construcción. Sueño con crear comunidades educativas accesibles y compartir la pasión por la búsqueda del conocimiento.',
    href: withBase('proyectos/'),
    cta: 'Ver proyectos'
  },
  /*{
    title: 'Contacto',
    text: '',
    href: withBase('contacto/'),
    cta: 'Abrir contacto'
  }*/
];
---

<MainLayout title="Inicio | Poski" description="Blog personal de proyectos e ideas">
  <section class="top-grid">
    <section class="panel hero-panel">
      <p class="eyebrow">Página Personal</p>
      <h1>Oscar Rivera Sánchez</h1>
      <p>
        Compartiendo mi emoción por el aprendizaje y la búsqueda de nuevos conocimientos. Este sitio mezcla mi trabajo de ingeniería con exploraciones personales, en mi intento por encontrar mi lugar en el mundo.
      </p>
      <a href="https://linkedin.com/in/oscar-poski"> Ver mi perfil de LinkedIn
      </a>
    </section>
  </section>

  <section class="bento-grid">
    {cards.map((card) => (
      <article class="panel bento-card">
        <h2>{card.title}</h2>
        <p>{card.text}</p>
        <a href={card.href}>{card.cta}</a>
      </article>
    ))}
  </section>
</MainLayout>
