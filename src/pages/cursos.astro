---
import Layout from '../layouts/main.astro';
import { CoursesGrid } from '@/components/CoursesGrid';
import { getLearningTracks } from '@/lib/curriculum';

const learningTracks = await getLearningTracks();
---

<Layout title="Cursos Disponibles">
  <section class="py-20 md:py-32">
    <div class="container mx-auto px-4">
      <div class="mb-16 text-center space-y-4">
        <h1 class="text-3xl font-bold md:text-5xl">
          <span class="bg-gradient-to-r from-yellow-600 via-amber-600 to-yellow-600 dark:from-yellow-400 dark:via-amber-600 dark:to-yellow-400 bg-clip-text text-transparent animate-gradient">
            Mis Notas
          </span>
        </h1>
        <p class="mx-auto max-w-3xl text-muted-foreground">
          Notas personales de temas que he estudiado últimamente. 
        </p>
      </div>

      <CoursesGrid client:load learningTracks={learningTracks} />
    </div>
  </section>
</Layout>
