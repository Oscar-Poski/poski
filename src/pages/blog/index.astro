---
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
const withBase = (path = '') => {
  const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
  return `${base}${path}`;
};

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<MainLayout title="Blog | Poski" description="Ideas y notas sobre tecnología y proyectos personales">
  <section class="panel page-header">
    <p class="eyebrow">Blog</p>
    <h1>Espacio para despejar las ideas que llenan mi cabeza</h1>
  </section>

  <section class="posts-grid">
    {posts.map((post) => (
      <article class="panel post-card">
        <p class="post-date">{post.data.publishedAt.toLocaleDateString('es-ES')}</p>
        <h2>{post.data.title}</h2>
        <p>{post.data.description}</p>
        <a href={withBase(`blog/${post.slug}/`)}>Leer artículo</a>
      </article>
    ))}
  </section>
</MainLayout>
