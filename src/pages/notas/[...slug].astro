---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const notes = await getCollection('notas', ({ data }) => !data.draft);

  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note, allNotes: notes }
  }));
}

const { note, allNotes } = Astro.props;
const { Content } = await render(note);

const groupsMap = new Map<string, { slug: string; title: string; order: number }[]>();

for (const item of allNotes) {
  const [section = 'General'] = item.slug.split('/');
  const sectionLabel = section.charAt(0).toUpperCase() + section.slice(1);

  if (!groupsMap.has(sectionLabel)) {
    groupsMap.set(sectionLabel, []);
  }

  groupsMap.get(sectionLabel)?.push({
    slug: item.slug,
    title: item.data.title,
    order: item.data.order
  });
}

const groups = [...groupsMap.entries()]
  .map(([section, sectionNotes]) => ({
    section,
    notes: sectionNotes.sort((a, b) => a.order - b.order || a.slug.localeCompare(b.slug))
  }))
  .sort((a, b) => a.section.localeCompare(b.section));
---

<DocsLayout
  title={`${note.data.title} | Notas`}
  description={note.data.description}
  groups={groups}
  currentSlug={note.slug}
>
  <h1>{note.data.title}</h1>
  {note.data.description && <p>{note.data.description}</p>}
  <hr />
  <Content />
</DocsLayout>
