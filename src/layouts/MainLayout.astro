---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Blog personal en Astro' } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Proyectos' },
  { href: '/contact', label: 'Contacto' }
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="site-bg"></div>
    <main class="shell">
      <header class="panel header-panel">
        <a class="brand" href="/">Poski</a>
        <nav>
          <ul>
            {navLinks.map((link) => (
              <li>
                <a href={link.href} class={currentPath.startsWith(link.href) && link.href !== '/' || currentPath === link.href ? 'active' : ''}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </header>

      <slot />

      <footer class="panel footer-panel">
        <p>Oscar Rivera Sánchez. Guadalajara, Jal. © {new Date().getFullYear()}</p>
      </footer>
    </main>
  </body>
</html>
