---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Blog personal de Oscar' } = Astro.props;
const currentPath = Astro.url.pathname;
const withBase = (path = '') => {
  const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
  return `${base}${path}`;
};

const navLinks = [
  { path: '', label: 'Inicio' },
  { path: 'blog/', label: 'Blog' },
  //{ path: 'notas/', label: 'Notas' },
  { path: 'about/', label: 'About' },
  { path: 'proyectos/', label: 'Proyectos' },
  { path: 'contacto/', label: 'Contacto' }
];
---

<!doctype html>
<html lang="es">
  <head>
    <link rel="icon" type="image/png" href={withBase('poski.png')} />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="site-bg"></div>
    <main class="shell">
      <header class="panel header-panel">
        <a class="brand" href={withBase('')}>Poski</a>
        <nav>
          <ul>
            {navLinks.map((link) => (
              <li>
                <a
                  href={withBase(link.path)}
                  class={link.path === ''
                    ? currentPath === withBase('')
                      ? 'active'
                      : ''
                    : currentPath.startsWith(withBase(link.path))
                      ? 'active'
                      : ''}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </header>

      <slot />

      <footer class="panel footer-panel">
        <p>Oscar Rivera Sánchez. Guadalajara, Jal. © {new Date().getFullYear()}</p>
      </footer>
    </main>
  </body>
</html>
